{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Backend",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--require",
                "ts-node/register"
            ],
            "args": [
                "${workspaceFolder}/server/src/app.ts"
            ],
            "cwd": "${workspaceFolder}/server",
            "envFile": "${workspaceFolder}/server/.env",
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ],
            "outFiles": [
                "${workspaceFolder}/server/dist/**/*.js"
            ]
        }
    ]
}
