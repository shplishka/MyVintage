NODE_ENV=development
PORT=4000

DATABASE_URL=

JWT_SECRET=change_me_in_production
REFRESH_TOKEN_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

MAX_POST_IMAGES=10

# Gemini AI (used for smart search)
# Get a key at https://aistudio.google.com/app/apikey
# Model used: gemini-2.5-flash-lite (free tier)
GEMINI_API_KEY=

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Development:
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
# Production:
# GOOGLE_CALLBACK_URL=http://node61.cs.colman.ac.il/api/auth/google/callback

# Frontend URL (used for post-OAuth redirect)
# Development:
CLIENT_URL=http://localhost:5173
# Production:
# CLIENT_URL=http://node61.cs.colman.ac.il
